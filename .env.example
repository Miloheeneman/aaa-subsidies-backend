# AAA-Subsidies Backend Environment Variables

# App
APP_ENV=development
APP_NAME=AAA-Subsidies
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=["http://localhost:5173","https://app.aaa-lexoffices.nl"]

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aaa_subsidies

# Auth / JWT
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# Resend (email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@aaa-lexoffices.nl
RESEND_FROM_NAME=AAA-Subsidies
# Komma-gescheiden mag; admin-wizard + deadline-mails + supportregel in klantmails
RESEND_ADMIN_EMAIL=subsidies@aaa-lexoffices.nl

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_starter_xxx
STRIPE_PRO_PRICE_ID=price_pro_xxx
# Legacy (still read for backwards compatibility):
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=aaa-subsidies-docs
R2_PUBLIC_URL=https://docs.aaa-lexoffices.nl
R2_ENDPOINT_URL=
